rules_version = '2';

// ─────────────────────────────────────────────────────────────────────────────
// Reef Villa — Firestore Security Rules
//
// Paste into Firebase Console → Firestore Database → Rules → Publish.
// Or deploy via CLI:  firebase deploy --only firestore:rules
//
// Model:
//   • Public, unauthenticated traffic can READ the catalogue + site content
//     (properties, settings, testimonials) and CREATE guest-side records
//     (bookings, guests, transactions, notifications, testimonials).
//   • Authenticated users own their /users/{uid} profile doc.
//   • Admins (role == 'admin' on their user doc) can read/write everything.
// ─────────────────────────────────────────────────────────────────────────────
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ────────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Admin allowlist — keep in sync with CLIENT_CONFIG.admin in
    // src/config/clientConfig.ts. Granting admin by the verified token email
    // (not just a writable `role` field) means the owner is never locked out
    // by a missing/stale users/{uid} doc, and stops a guest from elevating
    // themselves by writing role:'admin' to their own profile.
    function adminEmails() {
      return [
        'aioob.alharash@gmail.com'
      ];
    }

    function isAdminByEmail() {
      return isSignedIn()
        && request.auth.token.email != null
        && request.auth.token.email.lower() in adminEmails();
    }

    function isAdmin() {
      return isAdminByEmail()
        || (isSignedIn()
            && exists(/databases/$(database)/documents/users/$(request.auth.uid))
            && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    // ── User profiles ──────────────────────────────────────────────────────
    // Created on first sign-in by firestoreUsers.login(). Each user reads /
    // writes only their own doc; admins can manage all.
    match /users/{uid} {
      allow read:   if isOwner(uid) || isAdmin();
      // Users manage their own profile, but only an allowlisted admin may
      // assign the privileged 'admin' role — a guest cannot self-promote.
      allow create: if isOwner(uid) && (isAdmin() || request.resource.data.role != 'admin');
      allow update: if isAdmin()
        || (isOwner(uid) && request.resource.data.role == resource.data.role);
      allow delete: if isAdmin();
    }

    // ── Public catalogue & site content ────────────────────────────────────
    // `properties` and `settings` are also written on initial bootstrap by any
    // signed-in user so a fresh admin can seed the catalogue on first login.
    match /properties/{id} {
      allow read;
      allow write: if isSignedIn();
    }

    match /settings/{id} {
      allow read;
      // The iCal sync endpoint runs with the firebase-admin SDK (server-only)
      // so it bypasses these rules; admin UI writes still require role=admin.
      allow write: if isAdmin();
    }

    // Testimonials: public submissions, admin moderation.
    match /testimonials/{id} {
      allow read;
      allow create;
      allow update, delete: if isAdmin();
    }

    // ── Guest checkout flow ────────────────────────────────────────────────
    // The public booking page creates these as an unauthenticated guest. Only
    // admins can read / mutate after the fact.
    match /bookings/{id} {
      allow read:           if isAdmin();
      allow create;
      allow update, delete: if isAdmin();
    }

    match /guests/{id} {
      allow read:           if isAdmin();
      allow create;
      allow update, delete: if isAdmin();
    }

    match /transactions/{id} {
      allow read:           if isAdmin();
      allow create;
      allow update, delete: if isAdmin();
    }

    match /notifications/{id} {
      allow read, update:   if isAdmin();
      allow create;
      allow delete:         if isAdmin();
    }

    // ── Invoices (admin-managed) ───────────────────────────────────────────
    match /invoices/{id}      { allow read, write: if isAdmin(); }
    match /invoice_items/{id} { allow read, write: if isAdmin(); }

    // ── FCM device tokens for admin push notifications ─────────────────────
    // Collection name must match ADMIN_TOKENS_COLLECTION in
    // src/services/pushNotifications.ts.
    match /admin_tokens/{id} {
      allow read, write: if isAdmin();
    }

    // ── Default deny ───────────────────────────────────────────────────────
    // Any collection not listed above is off-limits.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
